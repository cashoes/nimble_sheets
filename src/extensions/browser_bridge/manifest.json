{
  "manifest_version": 3,
  "name": "NIMBLE Dice+ Bridge",
  "version": "1.0.0",
  "description": "Bridges the NIMBLE Character Tracker to Owlbear Rodeo Dice+.",
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_icon": {
      "128": "icon.png"
    },
    "default_title": "NIMBLE Dice+ Bridge"
  },
  "permissions": [
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://localhost/*",
        "file://*/*",
        "*://*.github.io/*"
      ],
      "js": [
        "content_tracker.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.owlbear.rodeo/*"
      ],
      "js": [
        "content_obr.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content_tracker.js",
        "content_obr.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}